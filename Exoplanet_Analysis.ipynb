from sklearn.model_selection import train_test_split from sklearn.ensemble import RandomForestClassifier from sklearn.metrics import classification_report,accuracy_score x=exo[['pl_rade','pl_orbper','st_teff']] y=exo['Habitable'] x_train,x_test,y_train,y_test=train_test_split(x,y,test_size=0.2,random_state=42)

